<!-- Configuratia sistemului de logare -->
<configuration>

    <!-- Afiseaza mesajele in consola IntelliJ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>

            <!-- Formatul mesajelor afisate -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Salvează erorile într-un fișier -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.FileAppender">

        <!-- Fișierul în care sunt stocate erorile -->
        <file>logs/errors.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <!--Se înregistrează doar mesajele de nivel ERROR -->
            <level>ERROR</level>
        </filter>
    </appender>

    <!-- Trimite mesajele către consolă -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>

        <!-- Trimite erorile și în fișier -->
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
